{
  "manifest_version": 3,
  "name": "Mo Access",
  "description": "Deterministic execution layer for the Mo Access voice assistant.",
  "version": "0.1.0",
  "permissions": ["activeTab", "scripting", "tabs", "storage", "alarms"],
  "host_permissions": ["http://localhost:8787/*", "<all_urls>"],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "background": {
    "service_worker": "assets/background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Mo Access"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["assets/content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["panel.html", "assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
